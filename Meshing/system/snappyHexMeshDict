FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


//SnappyHexMeshDict for trial run of one layer addLayers
//V1: lid at z=23m, blockMesh res: 0.8m, refinement level river: 2	no problem zones
//V2: V1 with     nSmoothSurfaceNormals 1 -> 3; nSmoothNormals 3 -> 5

///////////////////////////////
//This is Model Version 12 [small inlets] (OBJ)/ Mesh Version 1 Snapped Version
///////////////////////////////



//which of these steps to run
castellatedMesh	true;		//or false
snap 		true;		//or false
addLayers	true;		//or false

mergeTolerance 1e-6;		//somehow avoids FATAL ERROR when running


geometry
{
	"MV12Mini.obj"
	{
		type triSurfaceMesh;
		name terrain;
	}	
}


castellatedMeshControls
{
	//Refinement parameters
	maxLocalCells 4000000;		//trial and error, usual cell count/8 + buffer
	maxGlobalCells 20000000;	//trial and error, cell count usually ~7mio
	minRefinementCells 0;		//Wolf
	maxLoadUnbalance 0.10;		//Fed (also Wolf)
	nCellsBetweenLevels 3;		//Fed (3 for Wolf[agressive?], 1 for example flange [lenient?])

    	resolveFeatureAngle       30;		//Fed
    	allowFreeStandingZoneFaces false;	//error if not included, just set to false

	//Explicit feature edge refinement
	features
    	(
        	{file "MV12Mini.eMesh"; level 0;}
    	);
    	
    	// Surface Refinement
    	refinementSurfaces
    	{
        	terrain
        	{
        	level (0 0);
        	
        	regions
        	{
        		MV12_upper_river
        		{
        			level (2 2);
        			patchInfo { type wall; }
        		}
        		MV12_lower_river
        		{
        			level (2 2);
        			patchInfo { type wall; }
        		}
			MV12_inner_gravel
			{
				level (1 1);
				patchInfo { type wall; }
			}
			MV12_outer_gravel
			{
				level (0 0);
				patchInfo { type wall; }
			}
			MV12_vegetation
			{
				level (0 0);
				patchInfo { type wall; }
			}
			MV12_wallsSE
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_wallsSW
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_wallsNE
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_wallsNW
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_inlet1
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_inlet2
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_outlet
			{
				level (0 0);
				patchInfo  { type wall; }
			}
			MV12_lid
			{
				level (0 0);
				patchInfo  { type wall; }
			}
		}
		}

    	}
    	
    	// Region Refinement
    	refinementRegions
    	{

    	}
	// Region Selection
	locationInMesh (40 50 20);	//almost guaranteed to be in right position

}

snapControls
{
    nSmoothPatch 5;	//trial and error, any higher would smooth out terrain too much?
    tolerance 1.0;	//trial and error, bad cell issue currently bigger than gap issue
    nSolveIter 100;	//trial and error: 3rd:100, bad cells
    nRelaxIter 5;	//trial and error: 3rd:6, bad cells

    nFeatureSnapIter 10;	//trial and error, 3rd:10, bad cells
    implicitFeatureSnap true;
    explicitFeatureSnap true;
    multiRegionFeatureSnap true;
}

addLayersControls
{
    relativeSizes false; // Use absolute meters 

    layers
    {
        "terrain_MV12_lower_river" // Target patch from your OBJ 
        {
            nSurfaceLayers 1;
        }
    }

    expansionRatio 1.1; // Gentler transition than 1.2 
    
    // Total thickness of the layer stack
    // Setting this to 0.161m ensures yp > 8cm
    finalLayerThickness 0.161; 
    
    minThickness 0.01; // Allows thinning in tight spots to prevent crash 

    nGrow 0;
    featureAngle 130;
    slipFeatureAngle 30;
    nRelaxIter 5;
    nSmoothSurfaceNormals 3;		//V2 change from 1 to 3
    nSmoothNormals 5;			//V2 change from 3 to 5
    nSmoothThickness 10;
    maxFaceThicknessRatio 1.0;		// Increased to allow thick layers relative to background mesh
    maxThicknessToMedialRatio 0.3;
    minMedianAxisAngle 90;
    nLayerIter 50;
    nRelaxedIter 20;
    nBufferCellsNoExtrude 0;
}


meshQualityControls
{
    	maxNonOrtho 70;		
   	maxBoundarySkewness 20;
    	maxInternalSkewness 4;
    	maxConcave 80;
    	minVol 1e-13;
    	minTetQuality 1e-30;
    	minArea -1;
    	minTwist 0.02;
    	minDeterminant 0.001;
    	minFaceWeight 0.05;
    	minVolRatio 0.01;
    	minTriangleTwist -1;
    	minFlatness 0.5;
    	nSmoothScale 4;
    	errorReduction 0.75;
}

