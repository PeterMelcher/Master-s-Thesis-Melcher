FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "alpha.water.*"
    {
        nAlphaSubCycles     3;
        MULESCorr           yes;
        nAlphaCorr          3;
        nLimiterIter        10;
        extremaCoeff        1.0;
        cAlpha              0.5;
        icAlpha             0.1;
        scAlpha             0.0;

        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-16;
        relTol          1e-10;
        minIter         1;
        maxIter         1000;
    }

    "(pcorr|p_rgh)"
    {
        solver          PBiCGStab;

        preconditioner
        {
            preconditioner  GAMG;
            tolerance       1e-99;
            relTol          0.1;
            nVcycles        2;
            smoother        DICGaussSeidel;
            nPreSweeps      2;
            nPostSweeps     2;
            nFinestSweeps   2;
            cacheAgglomeration true;
            nCellsInCoarsestLevel 100;
            agglomerator    faceAreaPair;
            mergeLevels     1;
        }

        tolerance       1e-99;
        relTol          1e-3;
        minIter         1;
        maxIter         50;
    }

    "(pcorrFinal|p_rghFinal)"
    {
        solver          PBiCGStab;

        preconditioner
        {
            preconditioner  GAMG;
            tolerance       1e-99;
            relTol          0.01;
            nVcycles        2;
            smoother        DICGaussSeidel;
            nPreSweeps      2;
            nPostSweeps     2;
            nFinestSweeps   2;
            cacheAgglomeration true;
            nCellsInCoarsestLevel 100;
            agglomerator    faceAreaPair;
            mergeLevels     1;
        }

        tolerance       1e-12;
        relTol          1e-4;
        minIter         2;
        maxIter         100;
    }

    U
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-08;
        relTol          0.001;
        nSweeps         2;
        minIter         1;
        maxIter         20;
    }

    UFinal
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-10;
        relTol          0.001;
        nSweeps         2;
        minIter         1;
        maxIter         20;
    }

    "(k|kFinal|epsilon|epsilonFinal)"
    {
        solver          GAMG;
        tolerance       1e-12;
        relTol          1e-4;
        smoother        DILU;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
        minIter         1;
        maxIter         20;
    }
}

PIMPLE
{
    momentumPredictor   no;
    nOuterCorrectors    1;
    nCorrectors         3;
    nNonOrthogonalCorrectors 3;
}

relaxationFactors
{
    fields
    {
        p_rgh           1.0;
        p_rghFinal      1.0;
    }
    equations
    {
        U               1.0;
        UFinal          1.0;
        "(k|epsilon)"       1.0;
        "(k|epsilon)Final"  1.0;
    }
}

