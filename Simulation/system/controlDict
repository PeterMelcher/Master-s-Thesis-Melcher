FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     interFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         300;

deltaT          1e-05;

writeControl    adjustableRunTime;

writeInterval   0.5;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxCo           0.4;

maxAlphaCo      0.35;

maxDeltaT       0.01;

functions
{
    max_U
    {
        type            volFieldValue;
        libs            ("libfieldFunctionObjects.so");
        regionType      all;
        operation       max;
        fields          (U);
        writeFields     false;
        writeControl    timeStep;
        writeInterval   1;
        log             true;
    }
    maxMag_U
    {
        type            volFieldValue;
        libs            ("libfieldFunctionObjects.so");
        regionType      all;
        operation       maxMag;
        fields          (U);
        writeFields     false;
        writeControl    timeStep;
        writeInterval   1;
        log             true;
    }
}

