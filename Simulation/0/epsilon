FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.0001;

boundaryField
{
    terrain_MV12_inlet1
    {
        type            fixedValue;
        value           uniform 0.0001;
    }
    terrain_MV12_inlet2
    {
        type            fixedValue;
        value           uniform 0.0001;
    }

    terrain_MV12_outlet
    {
        type            inletOutlet;
        inletValue      uniform 0.0001;
        value           uniform 0.0001;
    }

    terrain_MV12_upper_river
    {
        type            epsilonWallFunction;
        value           uniform 0.0001;
    }
    terrain_MV12_lower_river
    {
        type            epsilonWallFunction;
        value           uniform 0.0001;
    }
    terrain_MV12_inner_gravel
    {
        type            epsilonWallFunction;
        value           uniform 0.0001;
    }
    terrain_MV12_outer_gravel
    {
        type            epsilonWallFunction;
        value           uniform 0.0001;
    }
    terrain_MV12_vegetation
    {
        type            epsilonWallFunction;
        value           uniform 0.0001;
    }
    terrain_MV12_wallsSW				//inlet side wall
    {
        type            epsilonWallFunction;
        value           uniform 0.0001;
    }
    
    terrain_MV12_wallsNE				//outlet side wall
    {
        type            inletOutlet;
        inletValue      uniform 0.0001;
        value           uniform 0.0001;
    }
    terrain_MV12_lid
    {
        type            inletOutlet;
        inletValue      uniform 0.0001;
        value           uniform 0.0001;
    }
    terrain_MV12_wallsNW				//upper side wall
    {
        type            inletOutlet;
        inletValue      uniform 0.0001;
        value           uniform 0.0001;
    }
    terrain_MV12_wallsSE				//lower side wall
    {
        type            inletOutlet;
        inletValue      uniform 0.0001;
        value           uniform 0.0001;
    }
}

